# ============================================================================
# PhTS Backend - Environment Example
# Copy this file to .env.local and adjust values for your machine.
# ============================================================================

# ----------------------------------------------------------------------------
# Runtime
# ----------------------------------------------------------------------------
NODE_ENV=development
PORT=3001
START_SERVER=true
LOG_LEVEL=info
APP_VERSION=0.0.0
APP_COMMIT=local
APP_TIMEZONE=Asia/Bangkok
TZ=Asia/Bangkok
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3001

# ----------------------------------------------------------------------------
# Security / Auth
# ----------------------------------------------------------------------------
JWT_SECRET=change-me-min-32-chars
JWT_EXPIRES_IN=7d
DEMO_DISABLE_TOKEN_EXPIRY=false
DEMO_DISABLE_RATE_LIMIT=false

# ----------------------------------------------------------------------------
# Database
# ----------------------------------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change-me
DB_NAME=phts_system
DB_TIMEZONE=+07:00
DB_CONNECT_TIMEOUT_MS=5000

# ----------------------------------------------------------------------------
# Redis / Cache / Locks
# ----------------------------------------------------------------------------
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ----------------------------------------------------------------------------
# Sync / Data Governance
# ----------------------------------------------------------------------------
SYNC_HISTORY_ARTIFACTS_ENABLED=true
SYNC_RETENTION_DATA_ISSUES_DAYS=180
SYNC_RETENTION_USER_AUDITS_DAYS=180
SYNC_RETENTION_STAGE_RUNS_DAYS=120
SYNC_WORKER_ENABLED=true
SYNC_WORKER_POLL_MS=30000
SYNC_AUTO_MODE=DAILY
SYNC_AUTO_DAILY_HOUR=2
SYNC_AUTO_DAILY_MINUTE=0
SYNC_AUTO_INTERVAL_MINUTES=60
SYNC_AUTO_TIMEZONE=Asia/Bangkok

# ----------------------------------------------------------------------------
# Snapshot Worker
# ----------------------------------------------------------------------------
SNAPSHOT_WORKER_ENABLED=true
SNAPSHOT_WORKER_POLL_MS=5000
SNAPSHOT_WORKER_BATCH_LIMIT=20
SNAPSHOT_OUTBOX_MAX_ATTEMPTS=8
SNAPSHOT_OUTBOX_RETRY_BASE_SECONDS=30
SNAPSHOT_OUTBOX_RETRY_MAX_SECONDS=1800
SNAPSHOT_OUTBOX_PROCESSING_TIMEOUT_SECONDS=300

# ----------------------------------------------------------------------------
# Notification Outbox Worker / Retry
# ----------------------------------------------------------------------------
NOTIFICATION_OUTBOX_WORKER_ENABLED=true
NOTIFICATION_OUTBOX_WORKER_POLL_MS=5000
NOTIFICATION_OUTBOX_WORKER_BATCH_LIMIT=100
NOTIFICATION_OUTBOX_MAX_ATTEMPTS=8
NOTIFICATION_OUTBOX_RETRY_BASE_SECONDS=30
NOTIFICATION_OUTBOX_RETRY_MAX_SECONDS=1800
NOTIFICATION_OUTBOX_PROCESSING_TIMEOUT_SECONDS=300

# ----------------------------------------------------------------------------
# Signature Refresh
# ----------------------------------------------------------------------------
SIGNATURE_REFRESH_DELAY_MS=1500
SIGNATURE_REFRESH_COOLDOWN_MS=5000

# ----------------------------------------------------------------------------
# Integrations - OCR
# ----------------------------------------------------------------------------
OCR_WORKER_ENABLED=true
OCR_SERVICE_URL=http://localhost:8088
OCR_HTTP_TIMEOUT_MS=60000
OCR_FILE_TIMEOUT_MS=60000
OCR_FILE_RETRY_COUNT=2

# ----------------------------------------------------------------------------
# Rate Limits
# ----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=5

# ----------------------------------------------------------------------------
# Jobs - Backup
# ----------------------------------------------------------------------------
BACKUP_ENABLED=false
BACKUP_WORKER_ENABLED=true
BACKUP_WORKER_POLL_MS=30000
BACKUP_COMMAND=/usr/bin/bash
BACKUP_ARGS=["src/scripts/ops/backup/backup.sh"]
BACKUP_WORKDIR=/absolute/path/to/phts-project/backend
BACKUP_TIMEOUT_MS=300000
BACKUP_JOB_TIMEZONE=Asia/Bangkok

# ----------------------------------------------------------------------------
# Jobs - Workforce Compliance Alerts
# ----------------------------------------------------------------------------
OPS_JOB_TIMEZONE=Asia/Bangkok

# ----------------------------------------------------------------------------
# Test Database (optional, for integration/e2e)
# ----------------------------------------------------------------------------
TEST_DB_HOST=127.0.0.1
TEST_DB_PORT=3306
TEST_DB_USER=root
TEST_DB_PASSWORD=
TEST_DB_NAME=phts_system_test
TEST_DB_WAIT_RETRIES=30
TEST_DB_WAIT_DELAY_MS=1000
